	<div  class="vc_col-sm-6 vc_col-xs-6 wpb_column column_container vc_column_container col border_right_desktop_2px border_right_phone_0px border_color_ffffff border_style_solid "  data-padding-pos="all" data-has-bg-color="false" data-bg-color="" data-bg-opacity="1" data-animation="" data-delay="0" >
